---
import Layout from '../../layouts/Layout.astro'
import { createSupabaseServerClient } from '../../lib/supabase-server'

const { client: supabase } = createSupabaseServerClient()
const token = Astro.locals.token as string | undefined
let authUser: any = null
let profile: any = null
if (token) {
  const { data: { user } } = await supabase.auth.getUser(token)
  authUser = user
  if (authUser) {
    profile = (await supabase.from('profiles').select('*').eq('id', authUser.id).single()).data
  }
}

let query = supabase
  .from('counselling')
  .select('*')
  .order('created_at', { ascending: false })

const { data: records } = await query

let insertError: string | null = null

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const action = form.get('action') as string

  if (action === 'delete') {
    const id = form.get('id') as string
    const { error } = await supabase.from('counselling').delete().eq('id', id)
    if (!error) return Astro.redirect('/counselling')
    insertError = error.message
  } else {
    const id = form.get('id') as string
    const payload = {
      name: form.get('name') as string,
      mobile: form.get('mobile') as string,
      dob: form.get('dob') as string || null,
      referer_name: form.get('referer_name') as string,
      gpa: form.get('gpa') as string,
      permanent_address: form.get('permanent_address') as string,
      temporary_address: form.get('temporary_address') as string,
      city_choice: form.get('city_choice') as string,
      job_included: form.get('job_included') === 'on',
      qualification: form.get('qualification') as string || null,
      passed_year: form.get('passed_year') ? parseInt(form.get('passed_year') as string) : null,
      visa_type: form.get('visa_type') as string,
      contact_number: form.get('contact_number') as string,
      remarks: form.get('remarks') as string,
    }
    let error
    if (id) {
      ({ error } = await supabase.from('counselling').update(payload).eq('id', id))
    } else {
      ({ error } = await supabase.from('counselling').insert({ ...payload, counsellor_id: authUser?.id ?? '00000000-0000-0000-0000-000000000000' }))
    }
    if (!error) {
      return Astro.redirect('/counselling')
    }
    insertError = error.message
  }
}
const recordsJson = JSON.stringify(records)
const debugJson = JSON.stringify(records?.[0] ?? {})
---

<Layout title="Counselling" user={profile}>
  <div class="space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
      <div>
        <h1 class="text-xl lg:text-2xl font-bold text-text-primary">Counselling Records</h1>
        <p class="text-sm text-text-muted mt-1">Manage pre-enrollment counselling sessions</p>
      </div>
      <button id="new-counselling-btn" class="btn-primary self-start sm:self-auto">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
        New Record
      </button>
    </div>

    <input type="text" id="search-input" placeholder="Search by name or mobile..." class="input-field w-full sm:max-w-xs" />

    {insertError && (
      <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm">{insertError}</div>
    )}

    <div class="card mobile-table">
      <table class="table-base">
        <thead>
          <tr>
            <th>Name</th>
            <th>Mobile</th>
            <th>Qualification</th>
            <th>City Choice</th>
            <th>Visa Type</th>
            <th>Job</th>
            <th>Date</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody id="records-table">
          {records?.map(r => {
            const displayName = r.name || r.referer_name || 'Unknown'
            const displayMobile = r.mobile || r.contact_number || '-'
            return (
            <tr class="group cursor-pointer" onclick={`openEditModal('${r.id}')`}>
              <td>
                <div class="flex items-center gap-3 flex-nowrap pointer-events-none">
                  <div class="w-8 h-8 rounded-full bg-gradient-to-br from-primary-400 to-violet-500 flex items-center justify-center text-white text-xs font-bold shrink-0">
                    {displayName.charAt(0).toUpperCase()}
                  </div>
                  <span class="font-semibold text-text-primary whitespace-nowrap">{displayName}</span>
                </div>
              </td>
              <td class="text-text-secondary whitespace-nowrap">{displayMobile}</td>
              <td class="capitalize text-text-secondary whitespace-nowrap">{r.qualification || '-'}</td>
              <td class="text-text-secondary whitespace-nowrap">{r.city_choice || '-'}</td>
              <td class="text-text-secondary whitespace-nowrap">{r.visa_type || '-'}</td>
              <td>
                <span class={`status-badge whitespace-nowrap ${r.job_included ? 'bg-green-50 text-green-700 border border-green-200' : 'bg-gray-100 text-gray-500 border border-gray-200'}`}>
                  {r.job_included ? 'Yes' : 'No'}
                </span>
              </td>
              <td class="text-xs text-text-muted whitespace-nowrap">{new Date(r.created_at).toLocaleDateString()}</td>
              <td class="text-right">
                <div class="flex items-center justify-end gap-2">
                  <button type="button" class="edit-btn text-primary-600 hover:text-primary-700 text-sm font-semibold" data-id={r.id}>Edit</button>
                  <form method="POST" class="inline" onsubmit="return confirm('Delete this counselling record?')">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="id" value={r.id} />
                    <button type="submit" class="text-red-500 hover:text-red-700 text-sm font-semibold">Delete</button>
                  </form>
                </div>
              </td>
              </tr>
            )
          })}
          </tbody>
      </table>
      {(!records || records.length === 0) && (
        <div class="flex flex-col items-center py-16 text-text-muted">
          <svg class="w-16 h-16 mb-4 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          <p class="text-sm font-medium">No counselling records yet</p>
          <p class="text-xs mt-1">Click "New Record" to add the first entry.</p>
        </div>
      )}
    </div>

    <div id="counselling-modal" class="hidden fixed inset-0 bg-black/40 backdrop-blur-sm z-50 flex items-center justify-center p-4">
      <div class="bg-white rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto shadow-2xl animate-scale-in">
        <div class="border-b border-border-light px-6 py-4 flex items-center justify-between">
          <h2 class="text-lg font-bold text-text-primary">New Counselling Record</h2>
          <button type="button" id="close-modal" class="text-text-muted hover:text-text-primary transition-all duration-200 p-1 rounded-lg hover:bg-surface-hover">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
        </div>
        <form method="POST" class="p-6 space-y-4">
          <input type="hidden" name="id" id="record-id" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="input-label">Name *</label>
              <input type="text" name="name" required class="input-field" />
            </div>
            <div>
              <label class="input-label">Mobile *</label>
              <input type="tel" name="mobile" required class="input-field" />
            </div>
            <div>
              <label class="input-label">Date of Birth</label>
              <input type="date" name="dob" class="input-field" />
            </div>
            <div>
              <label class="input-label">Referer Name</label>
              <input type="text" name="referer_name" class="input-field" />
            </div>
            <div>
              <label class="input-label">GPA</label>
              <input type="text" name="gpa" placeholder="e.g. 3.5" class="input-field" />
            </div>
            <div>
              <label class="input-label">Qualification</label>
              <select name="qualification" class="input-field">
                <option value="">Select</option>
                <option value="+2">+2</option>
                <option value="bachelor">Bachelor</option>
                <option value="master">Master</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label class="input-label">Passed Year</label>
              <input type="number" name="passed_year" placeholder="e.g. 2023" class="input-field" />
            </div>
            <div>
              <label class="input-label">Visa to Apply</label>
              <select name="visa_type" class="input-field">
                <option value="">Select visa type</option>
                <option value="SSW">SSW (Specified Skilled Worker)</option>
                <option value="student">Student Visa</option>
                <option value="technical_intern">Technical Intern</option>
                <option value="engineer">Engineer</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label class="input-label">City Choice</label>
              <input type="text" name="city_choice" placeholder="e.g. Tokyo, Osaka" class="input-field" />
            </div>
            <div>
              <label class="input-label">Contact Number</label>
              <input type="tel" name="contact_number" class="input-field" />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="input-label">Permanent Address</label>
              <textarea name="permanent_address" rows={2} class="input-field"></textarea>
            </div>
            <div>
              <label class="input-label">Temporary Address</label>
              <textarea name="temporary_address" rows={2} class="input-field"></textarea>
            </div>
          </div>

          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" name="job_included" class="w-4 h-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500" />
            <span class="text-text-secondary">Job placement included</span>
          </label>

          <div>
            <label class="input-label">Remarks</label>
            <textarea name="remarks" rows={3} class="input-field"></textarea>
          </div>

          <div class="flex items-center gap-3 pt-2">
            <button type="submit" class="btn-primary">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Save Record
            </button>
            <button type="button" class="btn-secondary close-modal-btn">Cancel</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script id="records-data" type="application/json" set:html={recordsJson}></script>
  <script is:inline>
    const RECORDS = JSON.parse(document.getElementById('records-data').textContent);
    const btn = document.getElementById('new-counselling-btn');
    const modal = document.getElementById('counselling-modal');
    const modalTitle = modal?.querySelector('h2');
    const closeBtns = document.querySelectorAll('#close-modal, .close-modal-btn');
    const form = modal?.querySelector('form');
    const idField = document.getElementById('record-id');
    const submitBtn = form?.querySelector('button[type="submit"]');

    function openModal(record) {
      modal?.classList.remove('hidden');
      if (record) {
        modalTitle.textContent = 'Edit Counselling Record';
        submitBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"><\/svg> Update Record';
        idField.value = record.id;
        form.querySelector('[name="name"]').value = record.name ?? '';
        form.querySelector('[name="mobile"]').value = record.mobile ?? '';
        form.querySelector('[name="dob"]').value = record.dob ?? '';
        form.querySelector('[name="referer_name"]').value = record.referer_name ?? '';
        form.querySelector('[name="gpa"]').value = record.gpa ?? '';
        form.querySelector('[name="qualification"]').value = record.qualification ?? '';
        form.querySelector('[name="passed_year"]').value = record.passed_year ?? '';
        form.querySelector('[name="visa_type"]').value = record.visa_type ?? '';
        form.querySelector('[name="city_choice"]').value = record.city_choice ?? '';
        form.querySelector('[name="contact_number"]').value = record.contact_number ?? '';
        form.querySelector('[name="permanent_address"]').value = record.permanent_address ?? '';
        form.querySelector('[name="temporary_address"]').value = record.temporary_address ?? '';
        form.querySelector('[name="job_included"]').checked = record.job_included ?? false;
        form.querySelector('[name="remarks"]').value = record.remarks ?? '';
      } else {
        modalTitle.textContent = 'New Counselling Record';
        submitBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"><\/svg> Save Record';
        idField.value = '';
        form.reset();
      }
    }

    function openEditModal(id) {
      const record = RECORDS.find(r => r.id === id);
      if (record) openModal(record);
    }
    window.openEditModal = openEditModal;

    btn?.addEventListener('click', () => openModal(null));
    document.querySelectorAll('.edit-btn').forEach(el => {
      el.addEventListener('click', (e) => { e.stopPropagation(); openModal(RECORDS.find(r => r.id === el.dataset.id)); });
    });
    closeBtns.forEach(el => el.addEventListener('click', () => modal?.classList.add('hidden')));
    modal?.addEventListener('click', e => { if (e.target === modal) modal.classList.add('hidden'); });

    const searchInput = document.getElementById('search-input');
    const tableBody = document.getElementById('records-table');
    const allRows = Array.from(tableBody?.querySelectorAll('tr') ?? []);

    searchInput?.addEventListener('input', function() {
      const q = this.value.toLowerCase();
      allRows.forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
    });
  </script>
</Layout>
