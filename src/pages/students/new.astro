---
import Layout from '../../layouts/Layout.astro'
import { supabase } from '../../lib/supabase'

const user = Astro.locals.user as import('../../types/profile').Profile

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const name = form.get('name') as string
  const mobile = form.get('mobile') as string
  const email = form.get('email') as string
  const dob = form.get('dob') as string
  const address = form.get('address') as string
  const guardian_name = form.get('guardian_name') as string
  const guardian_mobile = form.get('guardian_mobile') as string
  const guardian_relation = form.get('guardian_relation') as string
  const marks_grade = form.get('marks_grade') as string
  const lead_source = form.get('lead_source') as string

  const { data, error } = await supabase.from('students').insert({
    name,
    mobile,
    email: email || null,
    dob: dob || null,
    address: address || null,
    guardian_name: guardian_name || null,
    guardian_mobile: guardian_mobile || null,
    guardian_relation: guardian_relation || null,
    marks_grade: marks_grade || null,
    lead_source: lead_source || 'walk_in',
    branch: user.branch,
    status: 'lead',
    created_by: user.id,
  }).select().single()

  if (!error && data) {
    return Astro.redirect(`/students/${data.id}`)
  }
}
---

<Layout title="New Student" user={user}>
  <div class="max-w-2xl">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Add New Student</h1>

    <form method="POST" class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="sm:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-1">Full Name *</label>
          <input type="text" name="name" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Mobile *</label>
          <input type="tel" name="mobile" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input type="email" name="email" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Date of Birth</label>
          <input type="date" name="dob" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Lead Source</label>
          <select name="lead_source" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none">
            <option value="walk_in">Walk-In</option>
            <option value="facebook">Facebook</option>
            <option value="tiktok">TikTok</option>
            <option value="website">Website</option>
            <option value="instagram">Instagram</option>
            <option value="friend_referral">Friend Referral</option>
            <option value="other">Other</option>
          </select>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-700 mb-2">Guardian</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <input type="text" name="guardian_name" placeholder="Name" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none" />
          <input type="tel" name="guardian_mobile" placeholder="Mobile" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none" />
          <input type="text" name="guardian_relation" placeholder="Relation" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Marks / Grade</label>
        <input type="text" name="marks_grade" placeholder="e.g. 3.8 GPA / 85%" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none" />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Address</label>
        <textarea name="address" rows={2} class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none"></textarea>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="px-6 py-2.5 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors">
          Save Student
        </button>
        <a href="/students" class="px-6 py-2.5 border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors">
          Cancel
        </a>
      </div>
    </form>
  </div>
</Layout>
