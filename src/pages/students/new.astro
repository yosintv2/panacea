---
import Layout from '../../layouts/Layout.astro'
import { createSupabaseServerClient } from '../../lib/supabase-server'

const { client: supabase } = createSupabaseServerClient()
const token = Astro.locals.token as string | undefined
let authUser: any = null
let profile: any = null
if (token) {
  const { data: { user } } = await supabase.auth.getUser(token)
  authUser = user
  if (authUser) {
    profile = (await supabase.from('profiles').select('*').eq('id', authUser.id).single()).data
  }
}

const editId = Astro.url.searchParams.get('id')
let student: any = null
if (editId) {
  const { data } = await supabase.from('students').select('*').eq('id', editId).single()
  student = data
}

let insertError: string | null = null

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const name = form.get('name') as string
  const mobile = form.get('mobile') as string
  const dob = form.get('dob') as string
  const join_date = form.get('join_date') as string
  const address = form.get('address') as string
  const marks = form.get('marks') as string
  const attendance = form.get('attendance') as string
  const guardian_mobile = form.get('guardian_mobile') as string
  const lead_source = form.get('lead_source') as string

  const payload = {
    name,
    mobile,
    dob: dob || null,
    join_date: join_date || null,
    address: address || null,
    marks_grade: marks || null,
    attendance: attendance ? parseInt(attendance) : null,
    guardian_mobile: guardian_mobile || null,
    lead_source: lead_source || 'walk_in',
  }

  if (editId) {
    const { error } = await supabase.from('students').update({ ...payload, updated_at: new Date().toISOString() }).eq('id', editId)
    if (!error) return Astro.redirect(`/students/${editId}`)
    insertError = error?.message ?? 'Unknown error'
  } else {
    const { data, error } = await supabase.from('students').insert({
      ...payload,
      branch: profile?.branch ?? 'kathmandu',
      status: 'lead',
      created_by: authUser?.id ?? '00000000-0000-0000-0000-000000000000',
    }).select().single()
    if (!error && data) return Astro.redirect(`/students/${data.id}`)
    insertError = error?.message ?? 'Unknown error'
  }
}
---

<Layout title={editId ? 'Edit Student' : 'New Student'} user={profile}>
  <div class="max-w-2xl space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
      <div>
        <h1 class="text-xl lg:text-2xl font-bold text-text-primary">{editId ? 'Edit Student' : 'Add New Student'}</h1>
        <p class="text-sm text-text-muted mt-1">{editId ? 'Update student information' : 'Register a new student in the system'}</p>
      </div>
      <a href={editId ? `/students/${editId}` : '/students'} class="btn-secondary text-sm self-start sm:self-auto">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
        Back
      </a>
    </div>

    {insertError && (
      <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm">{insertError}</div>
    )}

    <form method="POST" class="space-y-6">
      <div class="card">
        <div class="card-header">
          <h2 class="text-sm font-bold text-text-primary">Student Information</h2>
        </div>
        <div class="card-body space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="input-label">Name *</label>
              <input type="text" name="name" required class="input-field" value={student?.name ?? ''} />
            </div>
            <div>
              <label class="input-label">Mobile Number *</label>
              <input type="tel" name="mobile" required class="input-field" value={student?.mobile ?? ''} />
            </div>
            <div>
              <label class="input-label">Date of Birth</label>
              <input type="date" name="dob" class="input-field" value={student?.dob ?? ''} />
            </div>
            <div>
              <label class="input-label">Date of Join</label>
              <input type="date" name="join_date" class="input-field" value={student?.join_date ?? ''} />
            </div>
          </div>
          <div>
            <label class="input-label">Address</label>
            <textarea name="address" rows={2} class="input-field">{student?.address ?? ''}</textarea>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h2 class="text-sm font-bold text-text-primary">Academic Details</h2>
        </div>
        <div class="card-body">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="input-label">Marks</label>
              <input type="text" name="marks" placeholder="e.g. 3.8 GPA / 85%" class="input-field" value={student?.marks_grade ?? ''} />
            </div>
            <div>
              <label class="input-label">Attendance %</label>
              <input type="number" name="attendance" placeholder="e.g. 90" class="input-field" value={student?.attendance ?? ''} />
            </div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h2 class="text-sm font-bold text-text-primary">Guardian & Source</h2>
        </div>
        <div class="card-body">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="input-label">Guardian Number <span class="text-text-muted">(optional)</span></label>
              <input type="tel" name="guardian_mobile" placeholder="Guardian phone number" class="input-field" value={student?.guardian_mobile ?? ''} />
            </div>
            <div>
              <label class="input-label">Lead Source</label>
              <select name="lead_source" class="input-field">
                {['walk_in', 'facebook', 'tiktok', 'website', 'instagram', 'friend_referral', 'other'].map(src => (
                  <option value={src} selected={student?.lead_source === src}>{src.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase())}</option>
                ))}
              </select>
            </div>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <button type="submit" class="btn-primary">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          {editId ? 'Update Student' : 'Save Student'}
        </button>
        <a href={editId ? `/students/${editId}` : '/students'} class="btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</Layout>
