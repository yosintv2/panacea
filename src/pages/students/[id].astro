---
import Layout from '../../layouts/Layout.astro'
import { supabase } from '../../lib/supabase'

const user = Astro.locals.user as import('../../types/profile').Profile
const { id } = Astro.params

const { data: student } = await supabase
  .from('students')
  .select('*')
  .eq('id', id)
  .single()

if (!student) return Astro.redirect('/students')

const { data: counselling } = await supabase
  .from('counselling')
  .select('*')
  .eq('student_id', id)
  .order('created_at', { ascending: false })
  .limit(1)
  .single()

const { data: followups } = await supabase
  .from('followups')
  .select('*')
  .eq('student_id', id)
  .order('next_date', { ascending: true })

const { data: documents } = await supabase
  .from('documents')
  .select('*')
  .eq('student_id', id)

const { data: journey } = await supabase
  .from('student_journey')
  .select('*')
  .eq('student_id', id)
  .order('created_at', { ascending: false })
---

<Layout title={student.name} user={user}>
  <div class="max-w-4xl space-y-6">
    <div class="flex items-start justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">{student.name}</h1>
        <p class="text-sm text-gray-500">
          {student.mobile} {student.email ? `| ${student.email}` : ''}
        </p>
      </div>
      <span class="text-xs font-medium capitalize px-3 py-1 rounded-full bg-indigo-100 text-indigo-700">
        {student.status.replace(/_/g, ' ')}
      </span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h2 class="text-base font-semibold text-gray-900 mb-3">Details</h2>
          <dl class="grid grid-cols-2 gap-4 text-sm">
            <div><dt class="text-gray-500">DOB</dt><dd class="font-medium">{student.dob ?? '-'}</dd></div>
            <div><dt class="text-gray-500">Address</dt><dd class="font-medium">{student.address ?? '-'}</dd></div>
            <div><dt class="text-gray-500">Guardian</dt><dd class="font-medium">{student.guardian_name ?? '-'}</dd></div>
            <div><dt class="text-gray-500">Guardian Mobile</dt><dd class="font-medium">{student.guardian_mobile ?? '-'}</dd></div>
            <div><dt class="text-gray-500">Lead Source</dt><dd class="font-medium capitalize">{student.lead_source.replace(/_/g, ' ')}</dd></div>
            <div><dt class="text-gray-500">Branch</dt><dd class="font-medium capitalize">{student.branch}</dd></div>
            <div><dt class="text-gray-500">Marks</dt><dd class="font-medium">{student.marks_grade ?? '-'}</dd></div>
            <div><dt class="text-gray-500">Joined</dt><dd class="font-medium">{new Date(student.created_at).toLocaleDateString()}</dd></div>
          </dl>
        </div>

        {counselling && (
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-base font-semibold text-gray-900 mb-3">Counselling Record</h2>
            <dl class="grid grid-cols-2 gap-4 text-sm">
              <div><dt class="text-gray-500">Referer</dt><dd class="font-medium">{counselling.referer_name ?? '-'}</dd></div>
              <div><dt class="text-gray-500">GPA</dt><dd class="font-medium">{counselling.gpa ?? '-'}</dd></div>
              <div><dt class="text-gray-500">Qualification</dt><dd class="font-medium">{counselling.qualification ?? '-'}</dd></div>
              <div><dt class="text-gray-500">Passed Year</dt><dd class="font-medium">{counselling.passed_year ?? '-'}</dd></div>
              <div><dt class="text-gray-500">City Choice</dt><dd class="font-medium">{counselling.city_choice ?? '-'}</dd></div>
              <div><dt class="text-gray-500">Country</dt><dd class="font-medium">{counselling.country_interest ?? '-'}</dd></div>
              <div><dt class="text-gray-500">Visa Type</dt><dd class="font-medium">{counselling.visa_type ?? '-'}</dd></div>
              <div><dt class="text-gray-500">Job Included</dt><dd class="font-medium">{counselling.job_included ? 'Yes' : 'No'}</dd></div>
            </dl>
            {counselling.remarks && <p class="mt-3 text-sm text-gray-600"><span class="text-gray-500">Remarks:</span> {counselling.remarks}</p>}
          </div>
        )}

        {journey && journey.length > 0 && (
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-base font-semibold text-gray-900 mb-3">Journey Timeline</h2>
            <div class="relative pl-6 border-l-2 border-indigo-200 space-y-4">
              {journey.map(j => (
                <div class="relative">
                  <div class="absolute -left-[25px] w-3 h-3 bg-indigo-500 rounded-full border-2 border-white" />
                  <div class="text-sm">
                    <span class="font-medium capitalize text-gray-900">{j.stage.replace(/_/g, ' ')}</span>
                    <span class="text-gray-400 ml-2 text-xs">{new Date(j.created_at).toLocaleDateString()}</span>
                    {j.notes && <p class="text-gray-500 mt-0.5">{j.notes}</p>}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      <div class="space-y-6">
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h2 class="text-base font-semibold text-gray-900 mb-3">Documents</h2>
          {documents && documents.length > 0 ? (
            <ul class="space-y-2 text-sm">
              {documents.map(d => (
                <li class="flex items-center justify-between">
                  <span class="capitalize text-gray-700">{d.type.replace(/_/g, ' ')}</span>
                  <a href={d.file_url} target="_blank" class="text-indigo-600 hover:text-indigo-800 text-xs">View</a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-sm text-gray-400">No documents uploaded</p>
          )}
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h2 class="text-base font-semibold text-gray-900 mb-3">Follow-ups</h2>
          {followups && followups.length > 0 ? (
            <ul class="space-y-3 text-sm">
              {followups.map(f => (
                <li class="flex items-center justify-between">
                  <div>
                    <span class="text-gray-700">{new Date(f.next_date).toLocaleDateString()}</span>
                    {f.note && <p class="text-gray-400 text-xs">{f.note}</p>}
                  </div>
                  <span class={`text-xs font-medium px-2 py-0.5 rounded-full capitalize ${
                    f.status === 'completed' ? 'bg-green-100 text-green-700' :
                    f.status === 'missed' ? 'bg-red-100 text-red-700' :
                    'bg-yellow-100 text-yellow-700'
                  }`}>{f.status}</span>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-sm text-gray-400">No follow-ups scheduled</p>
          )}
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h2 class="text-base font-semibold text-gray-900 mb-3">Update Status</h2>
          <form method="POST" action={`/api/students/${id}/status`} class="space-y-3">
            <select name="status" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none">
              {['lead', 'documents_pending', 'applied', 'coe_received', 'visa_approved', 'joined', 'cancelled'].map(status => (
                <option value={status} selected={student.status === status}>{status.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase())}</option>
              ))}
            </select>
            <button type="submit" class="w-full py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors">
              Update
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</Layout>
