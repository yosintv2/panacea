---
import Layout from '../../layouts/Layout.astro'
import { createSupabaseServerClient } from '../../lib/supabase-server'

const { client: supabase } = createSupabaseServerClient()
const token = Astro.locals.token as string | undefined
let profile: any = null
if (token) {
  const { data: { user: authUser } } = await supabase.auth.getUser(token)
  if (authUser) {
    profile = (await supabase.from('profiles').select('*').eq('id', authUser.id).single()).data
  }
}
const { id } = Astro.params

const { data: student } = await supabase
  .from('students')
  .select('*')
  .eq('id', id)
  .single()

if (!student) return Astro.redirect('/students')

const { data: documents } = await supabase
  .from('documents')
  .select('*')
  .eq('student_id', id)

const { data: journey } = await supabase
  .from('student_journey')
  .select('*')
  .eq('student_id', id)
  .order('created_at', { ascending: false })

const statusStyles: Record<string, string> = {
  lead: 'bg-amber-50 text-amber-700 border-amber-200',
  documents_pending: 'bg-blue-50 text-blue-700 border-blue-200',
  applied: 'bg-violet-50 text-violet-700 border-violet-200',
  coe_received: 'bg-cyan-50 text-cyan-700 border-cyan-200',
  visa_approved: 'bg-emerald-50 text-emerald-700 border-emerald-200',
  joined: 'bg-green-50 text-green-700 border-green-200',
  cancelled: 'bg-red-50 text-red-700 border-red-200',
}

const tab = Astro.url.searchParams.get('tab') || 'details'
---

<Layout title={student.name} user={profile}>
  <div class="max-w-5xl space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-full bg-gradient-to-br from-primary-500 to-violet-600 flex items-center justify-center text-white text-lg sm:text-xl font-bold shrink-0 shadow-sm">
          {student.name.charAt(0).toUpperCase()}
        </div>
        <div class="min-w-0">
          <h1 class="text-xl sm:text-2xl font-bold text-text-primary truncate">{student.name}</h1>
          <p class="text-sm text-text-muted truncate">{student.mobile} {student.email ? `| ${student.email}` : ''}</p>
        </div>
      </div>
      <div class="flex items-center gap-3 self-start sm:self-auto">
        <a href={`/students/new?id=${id}`} class="btn-secondary text-sm px-3 py-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
          Edit
        </a>
        <span class={`status-badge border whitespace-nowrap ${statusStyles[student.status] || 'bg-gray-100 text-gray-600 border-gray-200'}`}>
          {student.status.replace(/_/g, ' ')}
        </span>
      </div>
    </div>

    <div class="border-b border-border overflow-x-auto hide-scrollbar">
      <nav class="flex gap-6 min-w-max">
        {['details', 'documents', 'timeline'].map(t => (
          <a
            href={`?tab=${t}`}
            class={`pb-3 text-sm font-semibold border-b-2 transition-all duration-200 ${
              tab === t
                ? 'border-primary-500 text-primary-700'
                : 'border-transparent text-text-muted hover:text-text-secondary hover:border-gray-300'
            }`}
          >
            {t.charAt(0).toUpperCase() + t.slice(1)}
          </a>
        ))}
      </nav>
    </div>

    {tab === 'details' && (
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 card">
          <div class="card-header">
            <h2 class="text-sm font-bold text-text-primary">Student Details</h2>
          </div>
          <div class="card-body">
            <dl class="grid grid-cols-1 sm:grid-cols-2 gap-6 text-sm">
              <div><dt class="text-xs font-semibold text-text-muted uppercase tracking-wider">DOB</dt><dd class="mt-1 font-semibold text-text-primary">{student.dob ?? '-'}</dd></div>
              <div><dt class="text-xs font-semibold text-text-muted uppercase tracking-wider">Branch</dt><dd class="mt-1 font-semibold text-text-primary capitalize">{student.branch}</dd></div>
              <div><dt class="text-xs font-semibold text-text-muted uppercase tracking-wider">Guardian</dt><dd class="mt-1 font-semibold text-text-primary">{student.guardian_name ?? '-'}</dd></div>
              <div><dt class="text-xs font-semibold text-text-muted uppercase tracking-wider">Guardian Mobile</dt><dd class="mt-1 font-semibold text-text-primary">{student.guardian_mobile ?? '-'}</dd></div>
              <div><dt class="text-xs font-semibold text-text-muted uppercase tracking-wider">Lead Source</dt><dd class="mt-1 font-semibold text-text-primary capitalize">{student.lead_source.replace(/_/g, ' ')}</dd></div>
              <div><dt class="text-xs font-semibold text-text-muted uppercase tracking-wider">Marks</dt><dd class="mt-1 font-semibold text-text-primary">{student.marks_grade ?? '-'}</dd></div>
              <div class="col-span-2"><dt class="text-xs font-semibold text-text-muted uppercase tracking-wider">Address</dt><dd class="mt-1 font-semibold text-text-primary">{student.address ?? '-'}</dd></div>
              <div><dt class="text-xs font-semibold text-text-muted uppercase tracking-wider">Date of Join</dt><dd class="mt-1 font-semibold text-text-primary">{student.join_date ?? '-'}</dd></div>
              <div><dt class="text-xs font-semibold text-text-muted uppercase tracking-wider">Created</dt><dd class="mt-1 font-semibold text-text-primary">{new Date(student.created_at).toLocaleDateString()}</dd></div>
            </dl>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <h2 class="text-sm font-bold text-text-primary">Update Status</h2>
          </div>
          <div class="card-body">
            <form method="POST" action={`/api/students/${id}/status`} class="space-y-3">
              <select name="status" class="input-field">
                {['lead', 'documents_pending', 'applied', 'coe_received', 'visa_approved', 'joined', 'cancelled'].map(status => (
                  <option value={status} selected={student.status === status}>{status.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase())}</option>
                ))}
              </select>
              <button type="submit" class="btn-primary w-full justify-center">Update Status</button>
            </form>
            <form method="POST" action={`/api/students/${id}/delete`} class="mt-3" onsubmit="return confirm('Delete this student permanently?')">
              <button type="submit" class="w-full py-2.5 border border-red-200 text-red-600 rounded-lg text-sm font-semibold hover:bg-red-50 transition-all duration-200 flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                Delete Now
              </button>
            </form>
          </div>
        </div>
      </div>
    )}

    {tab === 'documents' && (
      <div class="card">
        <div class="card-header">
          <h2 class="text-sm font-bold text-text-primary">Documents</h2>
        </div>
        <div class="card-body">
          {documents && documents.length > 0 ? (
            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {documents.map(d => (
                <div class="flex items-center justify-between p-3 border border-border rounded-lg hover:bg-surface-hover transition-colors">
                  <div class="flex items-center gap-3">
                    <svg class="w-8 h-8 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                    <span class="text-sm font-semibold text-text-primary capitalize">{d.type.replace(/_/g, ' ')}</span>
                  </div>
                  <a href={d.file_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-xs font-semibold text-primary-600 hover:text-primary-700">
                    View
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                  </a>
                </div>
              ))}
            </div>
          ) : (
            <div class="flex flex-col items-center py-12 text-text-muted">
              <svg class="w-12 h-12 mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
              <p class="text-sm font-medium">No documents uploaded</p>
            </div>
          )}
        </div>
      </div>
    )}

    {tab === 'timeline' && (
      <div class="card">
        <div class="card-header">
          <h2 class="text-sm font-bold text-text-primary">Journey Timeline</h2>
        </div>
        <div class="card-body">
          {journey && journey.length > 0 ? (
            <div class="relative pl-8 border-l-2 border-primary-200 space-y-6">
              {journey.map((j, idx) => (
                <div class="relative">
                  <div class="absolute -left-[33px] w-4 h-4 bg-primary-500 rounded-full border-2 border-white shadow-sm" />
                  <div class="text-sm">
                    <div class="flex items-center gap-2">
                      <span class="font-semibold text-text-primary capitalize">{j.stage.replace(/_/g, ' ')}</span>
                      <span class="text-xs text-text-muted">{new Date(j.created_at).toLocaleDateString()}</span>
                    </div>
                    {j.notes && <p class="text-text-secondary mt-1">{j.notes}</p>}
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="flex flex-col items-center py-12 text-text-muted">
              <svg class="w-12 h-12 mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <p class="text-sm font-medium">No timeline entries yet</p>
            </div>
          )}
        </div>
      </div>
    )}
  </div>
</Layout>
