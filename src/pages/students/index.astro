---
import Layout from '../../layouts/Layout.astro'
import StudentTable from '../../components/StudentTable.astro'
import { createSupabaseServerClient } from '../../lib/supabase-server'

const { client: supabase } = createSupabaseServerClient()
const token = Astro.locals.token as string | undefined
let profile: any = null
if (token) {
  const { data: { user: authUser } } = await supabase.auth.getUser(token)
  if (authUser) {
    profile = (await supabase.from('profiles').select('*').eq('id', authUser.id).single()).data
  }
}

let query = supabase
  .from('students')
  .select('*')
  .order('created_at', { ascending: false })

if (profile && profile?.role !== 'admin') {
  query = query.eq('branch', profile?.branch)
}

const search = Astro.url.searchParams.get('q')
if (search) {
  query = query.ilike('name', `%${search}%`)
}

const statusFilter = Astro.url.searchParams.get('status')
if (statusFilter) {
  query = query.eq('status', statusFilter)
}

const { data: students } = await query
const statusLabel = statusFilter?.replace(/_/g, ' ') || ''
---

<Layout title="Students" user={profile}>
  <div class="space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
      <div>
        <h1 class="text-xl lg:text-2xl font-bold text-text-primary">Students</h1>
        {statusFilter && (
          <p class="text-sm text-text-muted mt-1">Filtered by: <span class="font-semibold text-primary-600 capitalize">{statusLabel}</span></p>
        )}
      </div>
      <a href="/students/new" class="btn-primary self-start sm:self-auto">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
        New Student
      </a>
    </div>

    <div class="flex items-center gap-3 flex-wrap">
      <select id="status-filter" class="input-field w-auto min-w-0 max-w-full" onchange="if(this.value) window.location.href='?status=' + this.value; else window.location.href='/students'">
        <option value="">All Statuses</option>
        {['lead', 'documents_pending', 'applied', 'coe_received', 'visa_approved', 'joined', 'cancelled'].map(st => (
          <option value={st} selected={statusFilter === st}>{st.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase())}</option>
        ))}
      </select>
      {statusFilter && (
        <a href="/students" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-primary-50 text-primary-700 text-sm font-medium border border-primary-200 hover:bg-primary-100 transition-all duration-200">
          {statusLabel}
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </a>
      )}
      <input
        type="text"
        id="search-input"
        placeholder="Search by name..."
        class="input-field w-full sm:max-w-xs"
      />
    </div>

    <div id="table-wrapper" class="card overflow-hidden">
      <StudentTable students={students ?? []} />
      {(!students || students.length === 0) && (
        <div class="flex flex-col items-center py-16 text-text-muted">
          <svg class="w-16 h-16 mb-4 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" /></svg>
          <p class="text-sm font-medium">No students found</p>
          {statusFilter && <p class="text-xs mt-1">No students with status &ldquo;{statusLabel}&rdquo;</p>}
          {!statusFilter && <a href="/students/new" class="text-xs text-primary-600 hover:text-primary-700 mt-2 font-semibold">Add your first student</a>}
        </div>
      )}
    </div>
  </div>

  <script is:inline>
    const searchInput = document.getElementById('search-input');
    const tableWrapper = document.getElementById('table-wrapper');
    if (searchInput && tableWrapper) {
      const allRows = Array.from(tableWrapper.querySelectorAll('tbody tr'));
      searchInput.addEventListener('input', function() {
        const q = this.value.toLowerCase();
        allRows.forEach(row => {
          row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
      });
    }
  </script>
</Layout>
