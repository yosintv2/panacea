---
import Layout from '../../layouts/Layout.astro'
import { supabase } from '../../lib/supabase'

const user = Astro.locals.user as import('../../types/profile').Profile

const today = new Date()
const startOfMonth = new Date(today.getFullYear(), today.getMonth(), 1)
const endOfMonth = new Date(today.getFullYear(), today.getMonth() + 1, 0)

let query = supabase
  .from('followups')
  .select('*, students (id, name)')
  .gte('next_date', startOfMonth.toISOString().split('T')[0])
  .lte('next_date', endOfMonth.toISOString().split('T')[0])
  .order('next_date')

if (user.role !== 'admin') {
  query = query.eq('assigned_to', user.id)
}

const { data: monthFollowups } = await query

const daysInMonth = endOfMonth.getDate()
const firstDayOfWeek = startOfMonth.getDay()
const days = Array.from({ length: daysInMonth }, (_, i) => i + 1)
const dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat']
const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December']
---

<Layout title="Calendar" user={user}>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-bold text-gray-900">{monthNames[today.getMonth()]} {today.getFullYear()}</h1>
      <a href="/followups" class="text-sm text-indigo-600 hover:text-indigo-800 font-medium">Manage follow-ups</a>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="grid grid-cols-7 border-b border-gray-200">
        {dayNames.map(d => (
          <div class="px-3 py-2 text-xs font-medium text-gray-500 text-center">{d}</div>
        ))}
      </div>
      <div class="grid grid-cols-7">
        {Array.from({ length: firstDayOfWeek }).map((_, i) => (
          <div key={`empty-${i}`} class="min-h-[100px] border-b border-r border-gray-100 p-2" />
        ))}
        {days.map(day => {
          const dateStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`
          const dayFollowups = monthFollowups?.filter(f => f.next_date === dateStr) ?? []
          const isToday = day === today.getDate()
          return (
            <div class={`min-h-[100px] border-b border-r border-gray-100 p-2 ${isToday ? 'bg-indigo-50' : ''}`}>
              <div class={`text-sm font-medium mb-1 ${isToday ? 'text-indigo-600' : 'text-gray-700'}`}>{day}</div>
              {dayFollowups.slice(0, 2).map(f => (
                <div class="text-xs bg-yellow-100 text-yellow-800 px-1.5 py-0.5 rounded mb-0.5 truncate">
                  {(f.students as any)?.name}
                </div>
              ))}
              {dayFollowups.length > 2 && (
                <div class="text-xs text-gray-400">+{dayFollowups.length - 2} more</div>
              )}
            </div>
          )
        })}
      </div>
    </div>
  </div>
</Layout>
