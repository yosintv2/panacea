---
import Layout from '../../layouts/Layout.astro'
import { supabase } from '../../lib/supabase'

const user = Astro.locals.user as import('../../types/profile').Profile

let query = supabase
  .from('followups')
  .select('*, students (id, name, mobile)')
  .order('next_date', { ascending: true })

if (user.role !== 'admin') {
  query = query.eq('assigned_to', user.id)
}

const { data: followups } = await query
---

<Layout title="Follow-ups" user={user}>
  <div class="space-y-6">
    <h1 class="text-2xl font-bold text-gray-900">Follow-ups</h1>

    <div class="flex gap-2">
      <a href="?status=pending" class="px-3 py-1.5 text-sm font-medium rounded-lg {!Astro.url.searchParams.get('status') || Astro.url.searchParams.get('status') === 'pending' ? 'bg-indigo-100 text-indigo-700' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}">Pending</a>
      <a href="?status=completed" class="px-3 py-1.5 text-sm font-medium rounded-lg {Astro.url.searchParams.get('status') === 'completed' ? 'bg-indigo-100 text-indigo-700' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}">Completed</a>
      <a href="?status=missed" class="px-3 py-1.5 text-sm font-medium rounded-lg {Astro.url.searchParams.get('status') === 'missed' ? 'bg-indigo-100 text-indigo-700' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}">Missed</a>
    </div>

    <div class="overflow-x-auto bg-white rounded-xl border border-gray-200 shadow-sm">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200 bg-gray-50 text-left text-gray-600 font-medium">
            <th class="px-4 py-3">Student</th>
            <th class="px-4 py-3">Date</th>
            <th class="px-4 py-3">Note</th>
            <th class="px-4 py-3">Status</th>
          </tr>
        </thead>
        <tbody>
          {followups?.filter(f => !Astro.url.searchParams.get('status') || f.status === Astro.url.searchParams.get('status')).map(f => (
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="px-4 py-3">
                <a href={`/students/${f.student_id}`} class="font-medium text-gray-900 hover:text-indigo-600">
                  {(f.students as any)?.name ?? 'Unknown'}
                </a>
                <div class="text-xs text-gray-400">{(f.students as any)?.mobile}</div>
              </td>
              <td class="px-4 py-3 text-gray-700">{new Date(f.next_date).toLocaleDateString()}</td>
              <td class="px-4 py-3 text-gray-500 max-w-xs truncate">{f.note ?? '-'}</td>
              <td class="px-4 py-3">
                <span class={`text-xs font-medium px-2 py-0.5 rounded-full capitalize ${
                  f.status === 'completed' ? 'bg-green-100 text-green-700' :
                  f.status === 'missed' ? 'bg-red-100 text-red-700' :
                  'bg-yellow-100 text-yellow-700'
                }`}>{f.status}</span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>
