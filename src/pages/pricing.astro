---
import Layout from '../layouts/Layout.astro'

const plans = [
  {
    name: 'Starter',
    price: 'NPR 999',
    period: '/month',
    desc: 'For small consultancies getting started',
    features: ['2 Staff accounts', 'Up to 500 students', 'Basic dashboard', 'CSV export', 'Email support'],
    cta: 'Start Free',
    gradient: 'from-indigo-500 to-blue-500',
  },
  {
    name: 'Professional',
    price: 'NPR 2,999',
    period: '/month',
    desc: 'For growing consultancies',
    features: ['10 Staff accounts', 'Unlimited students', 'Advanced analytics', 'CSV export', 'Priority support', 'Calendar & follow-ups'],
    popular: true,
    cta: 'Start Free',
    gradient: 'from-indigo-600 to-violet-600',
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    desc: 'For multi-branch organizations',
    features: ['Unlimited staff', 'Multi-branch support', 'Custom integrations', 'AI features', 'Dedicated support', 'SLA guarantee'],
    cta: 'Contact sales',
    gradient: 'from-gray-700 to-gray-900',
  },
]
---

<Layout title="Pricing">
  <div class="min-h-screen hero-grid">
    <nav class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
      <a href="/">
        <img src="https://panacea.edu.np/wp-content/uploads/2023/02/panacea-logo.png" alt="Panacea" class="h-8 w-auto" />
      </a>
      <div class="flex items-center gap-6">
        <a href="/contact" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Contact</a>
        <a href="/login" class="text-sm font-semibold text-white bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-700 hover:to-violet-700 px-5 py-2.5 rounded-xl transition-all duration-200 shadow-lg shadow-indigo-600/20">Sign in</a>
      </div>
    </nav>

    <section class="max-w-7xl mx-auto px-6 pt-20 pb-32">
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-indigo-50 border border-indigo-200 text-sm font-medium text-indigo-700 mb-6 animate-fade-up">Simple Pricing</div>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight mb-4 animate-fade-up stagger-1">Transparent pricing,<br /><span class="gradient-text">no surprises.</span></h1>
        <p class="text-lg text-gray-600 max-w-xl mx-auto animate-fade-up stagger-2">Choose the plan that fits your consultancy. All plans include a 14-day free trial.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {plans.map((plan, i) => (
          <div class={`relative p-8 rounded-2xl border transition-all duration-300 animate-fade-up stagger-${i + 1} ${plan.popular ? 'border-indigo-500 bg-white shadow-2xl shadow-indigo-600/10 scale-[1.02]' : 'border-gray-100 bg-white hover:border-gray-200 hover:shadow-lg'}`}>
            {plan.popular && (
              <>
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full bg-gradient-to-r from-indigo-600 to-violet-600 text-white text-xs font-semibold shadow-lg shadow-indigo-600/30">Most Popular</div>
                <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-indigo-500/[0.02] to-transparent pointer-events-none" />
              </>
            )}
            <div class="text-sm font-semibold text-gray-900 mb-1">{plan.name}</div>
            <div class="flex items-baseline gap-1 mb-1">
              <span class="text-4xl font-extrabold text-gray-900">{plan.price}</span>
              <span class="text-sm text-gray-400">{plan.period}</span>
            </div>
            <p class="text-sm text-gray-500 mb-6">{plan.desc}</p>
            <ul class="space-y-3 mb-8">
              {plan.features.map(f => (
                <li class="flex items-start gap-3 text-sm text-gray-600">
                  <div class="w-5 h-5 rounded-full bg-indigo-50 flex items-center justify-center shrink-0 mt-0.5"><svg class="w-3 h-3 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg></div>
                  {f}
                </li>
              ))}
            </ul>
            <a
              href="/login"
              class={`block w-full text-center py-3 rounded-xl text-sm font-semibold transition-all duration-200 ${plan.popular ? 'bg-gradient-to-r from-indigo-600 to-violet-600 text-white hover:from-indigo-700 hover:to-violet-700 shadow-lg shadow-indigo-600/20 hover:shadow-xl hover:shadow-indigo-600/30' : 'border border-gray-200 text-gray-700 hover:bg-gray-50 hover:border-gray-300'}`}
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>

      <div class="mt-20 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-indigo-50 border border-indigo-200 text-sm font-medium text-indigo-700 mb-6">Trusted & Secure</div>
        <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-16 text-sm text-gray-400">
          <span class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>256-bit encryption</span>
          <span class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>99.9% uptime SLA</span>
          <span class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>Nepal-hosted data</span>
        </div>
      </div>
    </section>

    <footer class="border-t border-gray-100 bg-white">
      <div class="max-w-7xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <span class="text-sm text-gray-400">&copy; {new Date().getFullYear()} Panacea CRM.</span>
        <div class="flex items-center gap-6 text-sm text-gray-400">
          <a href="/" class="hover:text-gray-600 transition-colors">Home</a>
          <a href="/contact" class="hover:text-gray-600 transition-colors">Contact</a>
          <a href="/login" class="hover:text-gray-600 transition-colors">Sign in</a>
        </div>
      </div>
    </footer>
  </div>
</Layout>
