---
import Layout from '../layouts/Layout.astro'

const plans = [
  {
    name: 'Starter',
    price: 'NPR 999',
    period: '/month',
    desc: 'For small consultancies getting started',
    features: ['2 Staff accounts', 'Up to 500 students', 'Basic dashboard', 'CSV export', 'Email support'],
  },
  {
    name: 'Professional',
    price: 'NPR 2,999',
    period: '/month',
    desc: 'For growing consultancies',
    features: ['10 Staff accounts', 'Unlimited students', 'Advanced analytics', 'CSV export', 'Priority support', 'Calendar & follow-ups'],
    popular: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    desc: 'For multi-branch organizations',
    features: ['Unlimited staff', 'Multi-branch support', 'Custom integrations', 'AI features', 'Dedicated support', 'SLA guarantee'],
  },
]
---

<Layout title="Pricing">
  <div class="max-w-6xl mx-auto py-16 px-4">
    <div class="text-center mb-12">
      <h1 class="text-3xl font-bold text-gray-900">Simple, transparent pricing</h1>
      <p class="text-gray-500 mt-2">Choose the plan that fits your consultancy</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {plans.map(plan => (
        <div class={`rounded-xl border p-6 flex flex-col ${plan.popular ? 'border-indigo-500 ring-2 ring-indigo-500 bg-white' : 'border-gray-200 bg-white'}`}>
          {plan.popular && <span class="text-xs font-semibold text-indigo-600 bg-indigo-50 px-3 py-1 rounded-full self-start mb-3">Most Popular</span>}
          <h2 class="text-xl font-bold text-gray-900">{plan.name}</h2>
          <div class="mt-3">
            <span class="text-3xl font-bold text-gray-900">{plan.price}</span>
            <span class="text-gray-500 text-sm">{plan.period}</span>
          </div>
          <p class="text-sm text-gray-500 mt-2">{plan.desc}</p>
          <ul class="mt-6 space-y-3 flex-1">
            {plan.features.map(f => (
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <span class="text-indigo-500 mt-0.5">&#10003;</span>
                {f}
              </li>
            ))}
          </ul>
          <a
            href="/login"
            class={`mt-6 w-full text-center py-2.5 rounded-lg text-sm font-medium transition-colors ${plan.popular ? 'bg-indigo-600 text-white hover:bg-indigo-700' : 'border border-gray-300 text-gray-700 hover:bg-gray-50'}`}
          >
            Get started
          </a>
        </div>
      ))}
    </div>
  </div>
</Layout>
