---
import Layout from '../../layouts/Layout.astro'
import { supabase } from '../../lib/supabase'

const user = Astro.locals.user as import('../../types/profile').Profile

const { data: branchUsers } = user.role === 'admin'
  ? await supabase.from('profiles').select('*').order('created_at')
  : await supabase.from('profiles').select('*').eq('branch', user.branch).order('created_at')
---

<Layout title="Settings" user={user}>
  <div class="max-w-2xl space-y-6">
    <h1 class="text-2xl font-bold text-gray-900">Settings</h1>

    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-3">Profile</h2>
      <div class="text-sm space-y-2">
        <div><span class="text-gray-500">Name:</span> <span class="font-medium">{user.full_name}</span></div>
        <div><span class="text-gray-500">Email:</span> <span class="font-medium">{user.email}</span></div>
        <div><span class="text-gray-500">Role:</span> <span class="font-medium capitalize">{user.role}</span></div>
        <div><span class="text-gray-500">Branch:</span> <span class="font-medium capitalize">{user.branch}</span></div>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-3">Team Members</h2>
      <div class="space-y-3">
        {branchUsers?.map(p => (
          <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-b-0">
            <div>
              <div class="font-medium text-sm text-gray-900">{p.full_name}</div>
              <div class="text-xs text-gray-500">{p.email}</div>
            </div>
            <span class="text-xs font-medium capitalize px-2 py-0.5 rounded-full bg-gray-100 text-gray-700">{p.role}</span>
          </div>
        ))}
      </div>
    </div>

    {user.role === 'admin' && (
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <h2 class="text-base font-semibold text-gray-900 mb-3">Export</h2>
        <a
          href="/api/export/csv"
          class="inline-block px-4 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors"
        >
          Export Students CSV
        </a>
      </div>
    )}
  </div>
</Layout>
