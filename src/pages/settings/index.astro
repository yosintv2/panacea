---
import Layout from '../../layouts/Layout.astro'
import { createSupabaseServerClient } from '../../lib/supabase-server'

const { client: supabase } = createSupabaseServerClient()
const token = Astro.locals.token as string | undefined
let profile: any = null
if (token) {
  const { data: { user: authUser } } = await supabase.auth.getUser(token)
  if (authUser) {
    profile = (await supabase.from('profiles').select('*').eq('id', authUser.id).single()).data
  }
}

const { data: branchUsers } = profile?.role === 'admin'
  ? await supabase.from('profiles').select('*').order('created_at')
  : await supabase.from('profiles').select('*').eq('branch', profile?.branch).order('created_at')

const { data: adminEmails } = profile?.role === 'admin'
  ? await supabase.from('admin_emails').select('*').order('created_at')
  : { data: null }
---

<Layout title="Settings" user={profile}>
    <div class="max-w-3xl space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
      <h1 class="text-xl lg:text-2xl font-bold text-text-primary">Settings</h1>
      <a href="/api/export/csv" class="btn-secondary text-sm self-start sm:self-auto">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
        Export CSV
      </a>
    </div>

    <div class="card">
      <div class="card-header">
        <h2 class="text-sm font-bold text-text-primary">Profile</h2>
      </div>
      <div class="card-body">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary-500 to-violet-600 flex items-center justify-center text-white text-lg font-bold shrink-0 shadow-sm">
            {(profile?.full_name ?? '?').charAt(0).toUpperCase()}
          </div>
          <div class="text-sm space-y-1">
            <div class="font-semibold text-text-primary">{profile?.full_name}</div>
            <div class="text-text-muted">{profile?.email}</div>
            <div class="flex items-center gap-2 mt-1">
              <span class="status-badge border bg-primary-50 text-primary-700 border-primary-200 capitalize">{profile?.role}</span>
              <span class="status-badge border bg-gray-100 text-gray-600 border-gray-200 capitalize">{profile?.branch}</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <h2 class="text-sm font-bold text-text-primary">Team Members</h2>
      </div>
      <div class="card-body">
        <div class="space-y-1">
          {branchUsers?.map(p => (
            <div class="flex items-center justify-between py-3 border-b border-border-light last:border-b-0">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-primary-400 to-violet-500 flex items-center justify-center text-white text-xs font-bold shrink-0">
                  {p.full_name.charAt(0).toUpperCase()}
                </div>
                <div>
                  <div class="text-sm font-semibold text-text-primary">{p.full_name}</div>
                  <div class="text-xs text-text-muted">{p.email}</div>
                </div>
              </div>
              <div class="flex items-center gap-2">
                {profile?.role === 'admin' ? (
                  <form method="POST" action="/api/settings/update-role">
                    <input type="hidden" name="user_id" value={p.id} />
                    <select name="role" onchange="this.form.submit()" class="input-field text-xs py-1 w-auto" disabled={p.id === profile?.id}>
                      {['admin', 'counsellor', 'staff'].map(r => (
                        <option value={r} selected={p.role === r}>{r}</option>
                      ))}
                    </select>
                  </form>
                ) : (
                  <span class="status-badge border bg-gray-100 text-gray-600 border-gray-200 capitalize">{p.role}</span>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    {profile?.role === 'admin' && (
      <>
        <div class="card">
          <div class="card-header">
            <h2 class="text-sm font-bold text-text-primary">Admin Email Whitelist</h2>
          </div>
          <div class="card-body">
            <p class="text-xs text-text-muted mb-4">Users signing up with these email addresses will automatically get the admin role.</p>

            <form method="POST" action="/api/settings/add-admin-email" class="flex flex-col sm:flex-row gap-2 mb-4">
              <div class="relative flex-1">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                <input type="email" name="email" placeholder="admin@example.com" required class="input-field pl-9" />
              </div>
              <button type="submit" class="btn-primary shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                Add Email
              </button>
            </form>

            {adminEmails && adminEmails.length > 0 ? (
              <div class="space-y-1">
                {adminEmails.map(e => (
                  <div class="flex items-center justify-between py-3 border-b border-border-light last:border-b-0">
                    <div class="flex items-center gap-3">
                      <svg class="w-4 h-4 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                      <span class="text-sm font-semibold text-text-primary">{e.email}</span>
                    </div>
                    <form method="POST" action="/api/settings/remove-admin-email">
                      <input type="hidden" name="email" value={e.email} />
                      <button type="submit" class="text-xs font-semibold text-red-500 hover:text-red-700 transition-all duration-200">Remove</button>
                    </form>
                  </div>
                ))}
              </div>
            ) : (
              <p class="text-sm text-text-muted text-center py-4">No admin emails whitelisted yet.</p>
            )}
          </div>
        </div>

      </> 
    )}
  </div>
</Layout>
