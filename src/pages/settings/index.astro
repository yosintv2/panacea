---
import Layout from '../../layouts/Layout.astro'
import { supabase } from '../../lib/supabase'

const user = Astro.locals.user as import('../../types/profile').Profile

const { data: branchUsers } = user.role === 'admin'
  ? await supabase.from('profiles').select('*').order('created_at')
  : await supabase.from('profiles').select('*').eq('branch', user.branch).order('created_at')

const { data: adminEmails } = user.role === 'admin'
  ? await supabase.from('admin_emails').select('*').order('created_at')
  : { data: null }
---

<Layout title="Settings" user={user}>
  <div class="max-w-3xl space-y-6">
    <h1 class="text-2xl font-bold text-gray-900">Settings</h1>

    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-3">Profile</h2>
      <div class="text-sm space-y-2">
        <div><span class="text-gray-500">Name:</span> <span class="font-medium">{user.full_name}</span></div>
        <div><span class="text-gray-500">Email:</span> <span class="font-medium">{user.email}</span></div>
        <div><span class="text-gray-500">Role:</span> <span class="font-medium capitalize">{user.role}</span></div>
        <div><span class="text-gray-500">Branch:</span> <span class="font-medium capitalize">{user.branch}</span></div>
      </div>
    </div>

    {user.role === 'admin' && (
      <>
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h2 class="text-base font-semibold text-gray-900 mb-3">Team Members</h2>
          <div class="space-y-3 mb-4">
            {branchUsers?.map(p => (
              <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-b-0">
                <div>
                  <div class="font-medium text-sm text-gray-900">{p.full_name}</div>
                  <div class="text-xs text-gray-500">{p.email}</div>
                </div>
                <div class="flex items-center gap-2">
                  <form method="POST" action="/api/settings/update-role">
                    <input type="hidden" name="user_id" value={p.id} />
                    <select
                      name="role"
                      onchange="this.form.submit()"
                      class="text-xs px-2 py-1 border border-gray-300 rounded-md capitalize"
                      disabled={p.id === user.id}
                    >
                      {['admin', 'counsellor', 'staff'].map(r => (
                        <option value={r} selected={p.role === r}>{r}</option>
                      ))}
                    </select>
                  </form>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h2 class="text-base font-semibold text-gray-900 mb-3">Admin Email Whitelist</h2>
          <p class="text-xs text-gray-500 mb-4">
            Users signing up with these email addresses will automatically get the admin role.
          </p>

          <form method="POST" action="/api/settings/add-admin-email" class="flex gap-2 mb-4">
            <input
              type="email"
              name="email"
              placeholder="admin@example.com"
              required
              class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none"
            />
            <button
              type="submit"
              class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors"
            >
              Add Email
            </button>
          </form>

          {adminEmails && adminEmails.length > 0 ? (
            <div class="space-y-2">
              {adminEmails.map(e => (
                <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-b-0">
                  <span class="text-sm text-gray-700">{e.email}</span>
                  <form method="POST" action="/api/settings/remove-admin-email">
                    <input type="hidden" name="email" value={e.email} />
                    <button
                      type="submit"
                      class="text-xs text-red-500 hover:text-red-700 font-medium"
                    >
                      Remove
                    </button>
                  </form>
                </div>
              ))}
            </div>
          ) : (
            <p class="text-sm text-gray-400">No admin emails whitelisted yet.</p>
          )}
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h2 class="text-base font-semibold text-gray-900 mb-3">Export</h2>
          <a
            href="/api/export/csv"
            class="inline-block px-4 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200 transition-colors"
          >
            Export Students CSV
          </a>
        </div>
      </>
    )}

    {user.role !== 'admin' && (
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <h2 class="text-base font-semibold text-gray-900 mb-3">Team Members</h2>
        <div class="space-y-3">
          {branchUsers?.map(p => (
            <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-b-0">
              <div>
                <div class="font-medium text-sm text-gray-900">{p.full_name}</div>
                <div class="text-xs text-gray-500">{p.email}</div>
              </div>
              <span class="text-xs font-medium capitalize px-2 py-0.5 rounded-full bg-gray-100 text-gray-700">{p.role}</span>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</Layout>
