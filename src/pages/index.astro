---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Panacea - Education Consultancy CRM">
  <div class="hero-grid relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-indigo-600/5 via-transparent to-transparent pointer-events-none" />
    <nav class="relative z-10 max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
      <a href="/">
        <img src="https://panacea.edu.np/wp-content/uploads/2023/02/panacea-logo.png" alt="Panacea" class="h-8 w-auto" />
      </a>
      <div class="flex items-center gap-6">
        <a href="/pricing" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Pricing</a>
        <a href="/contact" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Contact</a>
        <a href="/login" class="text-sm font-semibold text-white bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-700 hover:to-violet-700 px-5 py-2.5 rounded-xl transition-all duration-200 shadow-lg shadow-indigo-600/20">Sign in</a>
      </div>
    </nav>

    <section class="relative z-10 max-w-7xl mx-auto px-6 pt-24 pb-32">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-indigo-50 border border-indigo-200 text-sm font-medium text-indigo-700 mb-8 animate-fade-up">
          <span class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse" />
          Trusted by education consultancies across Nepal
        </div>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold text-gray-900 leading-[1.08] tracking-tight mb-6 animate-fade-up stagger-1">
          Your Students,<br />
          <span class="gradient-text">Perfectly Managed.</span>
        </h1>
        <p class="text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed mb-10 animate-fade-up stagger-2">
          Replace spreadsheets and scattered records. Panacea is the all-in-one CRM built for education consultancies — managing students, counselling, applications, and follow-ups with ease.
        </p>
        <div class="flex items-center justify-center gap-4 animate-fade-up stagger-3">
          <a href="/login" class="group relative inline-flex items-center gap-2 px-8 py-3.5 bg-gradient-to-r from-indigo-600 to-violet-600 text-white font-semibold rounded-xl hover:from-indigo-700 hover:to-violet-700 transition-all duration-200 shadow-xl shadow-indigo-600/25 hover:shadow-indigo-600/40">
            Get Started Free
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="#features" class="px-8 py-3.5 border border-gray-300 text-gray-700 font-medium rounded-xl hover:bg-gray-50 transition-colors">
            Explore Features
          </a>
        </div>
        <div class="mt-12 flex items-center justify-center gap-8 sm:gap-12 text-sm text-gray-400 animate-fade-up stagger-4">
          <div class="flex flex-col items-center gap-0.5"><span class="text-2xl font-bold text-gray-900">500+</span><span>Students per branch</span></div>
          <div class="w-px h-10 bg-gray-200" />
          <div class="flex flex-col items-center gap-0.5"><span class="text-2xl font-bold text-gray-900">99.9%</span><span>Uptime</span></div>
          <div class="w-px h-10 bg-gray-200" />
          <div class="flex flex-col items-center gap-0.5"><span class="text-2xl font-bold text-gray-900">NPR</span><span>Affordable pricing</span></div>
        </div>
      </div>
    </section>

    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-gradient-to-r from-indigo-500/10 via-violet-500/10 to-fuchsia-500/10 blur-3xl pointer-events-none" />
  </div>

  <section id="features" class="max-w-7xl mx-auto px-6 py-28">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-indigo-50 border border-indigo-200 text-sm font-medium text-indigo-700 mb-6">Everything you need</div>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight mb-4">Built for Education Consultancies</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">From first inquiry to visa success — manage every step of the student journey in one platform.</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { icon: '👥', title: 'Student Management', desc: 'Complete student profiles with documents, status tracking, and communication history in one place.' },
        { icon: '💬', title: 'Counselling Sessions', desc: 'Log and manage counselling sessions with detailed notes, outcomes, and follow-up scheduling.' },
        { icon: '📊', title: 'Reports & Analytics', desc: 'Track student progress, counsellor performance, and business growth with real-time insights.' },
        { icon: '📄', title: 'Visa & Document Tracking', desc: 'Track application status, upload documents, and set expiry alerts for visas and passports.' },
        { icon: '📊', title: 'Dashboard Analytics', desc: 'Real-time insights into student pipeline, counsellor performance, and business growth.' },
        { icon: '🏢', title: 'Multi-Branch Support', desc: 'Manage multiple branches from one dashboard with role-based access control.' },
      ].map((f, i) => (
        <div class="group relative p-8 rounded-2xl bg-white border border-gray-100 hover:border-indigo-200 hover:shadow-xl hover:shadow-indigo-600/5 transition-all duration-300 animate-fade-up stagger-{i + 1}">
          <div class="text-3xl mb-4">{f.icon}</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">{f.title}</h3>
          <p class="text-sm text-gray-500 leading-relaxed">{f.desc}</p>
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-indigo-500/[0.02] to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" />
        </div>
      ))}
    </div>
  </section>

  <section class="bg-gray-900 hero-grid">
    <div class="max-w-7xl mx-auto px-6 py-28">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-indigo-900/40 border border-indigo-800/40 text-sm font-medium text-indigo-300 mb-6">Why Panacea</div>
          <h2 class="text-4xl sm:text-5xl font-extrabold text-white tracking-tight mb-6">From Paper to Platform in Days</h2>
          <p class="text-gray-400 text-lg leading-relaxed mb-8">Stop juggling spreadsheets, WhatsApp notes, and paper files. Panacea brings everything together in a secure, cloud-based platform your team will actually love using.</p>
          <div class="space-y-4">
            {[
              { label: 'Secure cloud storage', sub: 'All data encrypted at rest and in transit' },
              { label: 'Role-based access', sub: 'Staff, counsellor, admin — granular permissions' },
              { label: 'Export anytime', sub: 'CSV exports for reporting and compliance' },
            ].map((item, i) => (
              <div class="flex items-start gap-4 animate-fade-up stagger-{i + 1}">
                <div class="w-6 h-6 rounded-full bg-indigo-500/20 flex items-center justify-center shrink-0 mt-0.5"><svg class="w-3.5 h-3.5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg></div>
                <div><span class="text-white font-semibold">{item.label}</span><p class="text-sm text-gray-500">{item.sub}</p></div>
              </div>
            ))}
          </div>
        </div>
        <div class="relative">
          <div class="relative z-10 p-8 rounded-3xl bg-gray-800/50 border border-gray-700/50 backdrop-blur-sm">
            <div class="grid grid-cols-2 gap-4">
              {[
                { label: 'Students', value: '1,284', change: '+12%', up: true },
                { label: 'Applications', value: '847', change: '+8%', up: true },
                { label: 'Visa Success', value: '94%', change: '+3%', up: true },
                { label: 'Follow-ups', value: '56', change: '-2%', up: false },
              ].map(stat => (
                <div class="p-4 rounded-xl bg-gray-900/50 border border-gray-700/30">
                  <div class="text-xs text-gray-500 mb-1">{stat.label}</div>
                  <div class="text-2xl font-bold text-white">{stat.value}</div>
                  <span class={`text-xs font-medium ${stat.up ? 'text-emerald-400' : 'text-red-400'}`}>{stat.change}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="absolute -top-6 -right-6 w-64 h-64 bg-indigo-500/10 rounded-full blur-3xl pointer-events-none" />
          <div class="absolute -bottom-8 -left-8 w-48 h-48 bg-violet-500/10 rounded-full blur-3xl pointer-events-none" />
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-28 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight mb-4">Ready to Transform Your Consultancy?</h2>
      <p class="text-lg text-gray-600 mb-10">Join consultancies across Nepal using Panacea to manage students efficiently.</p>
      <a href="/login" class="group inline-flex items-center gap-2 px-8 py-3.5 bg-gradient-to-r from-indigo-600 to-violet-600 text-white font-semibold rounded-xl hover:from-indigo-700 hover:to-violet-700 transition-all duration-200 shadow-xl shadow-indigo-600/25 hover:shadow-indigo-600/40">
        Start Free
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <footer class="border-t border-gray-100 bg-white">
    <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="text-sm text-gray-400">&copy; {new Date().getFullYear()} Panacea CRM. All rights reserved.</span>
      <div class="flex items-center gap-6 text-sm text-gray-400">
        <a href="/pricing" class="hover:text-gray-600 transition-colors">Pricing</a>
        <a href="/contact" class="hover:text-gray-600 transition-colors">Contact</a>
        <a href="/login" class="hover:text-gray-600 transition-colors">Sign in</a>
      </div>
    </div>
  </footer>
</Layout>
