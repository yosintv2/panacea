---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Panacea - Education Consultancy CRM">
  <div class="min-h-screen flex flex-col">
    <header class="px-6 py-4 border-b border-gray-200 bg-white">
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <span class="text-xl font-bold text-indigo-600">Panacea</span>
        <div class="flex gap-4">
          <a href="/login" class="text-sm font-medium text-gray-600 hover:text-gray-900">Sign in</a>
          <a href="/pricing" class="text-sm font-medium text-gray-600 hover:text-gray-900">Pricing</a>
          <a href="/contact" class="text-sm font-medium text-gray-600 hover:text-gray-900">Contact</a>
        </div>
      </div>
    </header>

    <section class="flex-1 flex items-center justify-center px-6 py-20">
      <div class="max-w-2xl text-center">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">
          Education Consultancy <span class="text-indigo-600">CRM</span>
        </h1>
        <p class="text-lg text-gray-600 mb-8">
          Replace spreadsheets and paper records. Manage students, counselling, visa applications,
          and follow-ups — all in one place.
        </p>
        <div class="flex justify-center gap-4">
          <a
            href="/login"
            class="px-6 py-3 bg-indigo-600 text-white rounded-lg font-medium hover:bg-indigo-700 transition-colors"
          >
            Get Started
          </a>
          <a
            href="/pricing"
            class="px-6 py-3 border border-gray-300 text-gray-700 rounded-lg font-medium hover:bg-gray-50 transition-colors"
          >
            View Pricing
          </a>
        </div>
      </div>
    </section>

    <footer class="px-6 py-6 border-t border-gray-200 bg-white text-center text-sm text-gray-500">
      &copy; {new Date().getFullYear()} Panacea CRM. All rights reserved.
    </footer>
  </div>
</Layout>
