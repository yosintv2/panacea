---
const url = new URL(Astro.request.url)
const nextUrl = url.searchParams.get('next') ?? '/overview'
const code = url.searchParams.get('code')
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Authenticating - Panacea</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .card {
        background: rgba(255,255,255,0.03);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 16px;
        padding: 40px;
        text-align: center;
        max-width: 360px;
        width: 100%;
      }
      .spinner {
        width: 32px; height: 32px;
        border: 3px solid rgba(99,102,241,0.15);
        border-top-color: #6366f1;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 20px;
      }
      @keyframes spin { to { transform: rotate(360deg); } }
      h2 { color: #fff; font-size: 18px; font-weight: 700; margin-bottom: 8px; }
      p { color: #94a3b8; font-size: 14px; }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="spinner"></div>
      <h2>Signing you in</h2>
      <p>Please wait while we complete authentication.</p>
    </div>

    <div id="debug" style="color:#94a3b8;font-size:12px;margin-top:16px;text-align:left;max-width:360px;word-break:break-all"></div>

    <script type="module">
      import { supabase } from '../../lib/supabase'

      const $ = (id) => document.getElementById(id)
      const log = (msg) => { const d = $('debug'); if (d) d.innerHTML += '<div>' + msg + '</div>' }

      async function handleCallback() {
        try {
          const url = window.location.href
          const params = new URLSearchParams(window.location.search)
          const hash = window.location.hash.substring(1)
          const hashParams = new URLSearchParams(hash)
          const next = params.get('next') || '/overview'

          log('URL: ' + url)
          log('Hash: ' + window.location.hash)
          log('Search: ' + window.location.search)
          log('Next: ' + next)

          // PKCE flow: code in query string — exchange it for a session
          const code = params.get('code')
          log('Code param: ' + (code || 'none'))

          if (code) {
            log('Exchanging code for session...')
            const result = await supabase.auth.exchangeCodeForSession(code)
            log('Exchange error: ' + (result.error || 'none'))
            log('Session: ' + (result.data?.session?.access_token ? 'has token' : 'no token'))
            if (result.data?.session?.access_token) {
              document.cookie = 'sb-access-token=' + result.data.session.access_token + '; path=/; max-age=86400; SameSite=Lax'
              log('Cookie set, redirecting to ' + next)
              window.location.href = next
              return
            }
          }

          // Implicit flow: access_token in URL hash fragment
          const accessToken = hashParams.get('access_token')
          log('Hash access_token: ' + (accessToken || 'none'))

          if (accessToken) {
            const refreshToken = hashParams.get('refresh_token')
            log('Hash refresh_token: ' + (refreshToken || 'none'))
            if (refreshToken) {
              log('Setting session...')
              await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken })
              log('setSession done')
            }
            document.cookie = 'sb-access-token=' + accessToken + '; path=/; max-age=86400; SameSite=Lax'
            log('Cookie set, redirecting to ' + next)
            window.location.href = next
            return
          }

          log('No auth found, redirecting to /login')
          window.location.href = '/login'
        } catch (e) {
          log('ERROR: ' + e?.message + (e?.stack ? ' | ' + e.stack : ''))
        }
      }

      handleCallback()
    </script>
  </body>
</html>
