---
export interface Props {
  user: import('../types/profile').Profile
}

const { user } = Astro.props
const currentPath = Astro.url.pathname

const nav = [
  { href: '/overview', label: 'Dashboard',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>' },
  { href: '/students', label: 'Students',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" /></svg>' },
  { href: '/counselling', label: 'Counselling',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>' },
  { href: '/attendance', label: 'Attendance',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>' },
  { href: '/settings', label: 'Settings',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>' },
]
---

<aside
  id="sidebar"
  class="fixed inset-y-0 left-0 z-40 w-64 bg-white border-r border-border flex flex-col shrink-0 transition-transform duration-300 ease-in-out -translate-x-full lg:translate-x-0 lg:static lg:z-auto"
>
  <div class="h-16 flex items-center justify-between gap-3 px-5 border-b border-border-light">
    <div class="flex items-center gap-3">
      <img src="https://panacea.edu.np/wp-content/uploads/2023/02/panacea-logo.png" alt="Panacea" class="h-8 w-auto" />
    </div>
    <button id="sidebar-close" type="button" class="lg:hidden p-1 rounded-lg text-text-muted hover:text-text-primary hover:bg-surface-hover transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
  </div>

  <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-0.5">
    {nav.map(item => {
      const isActive = currentPath.startsWith(item.href)
      return (
        <a
          href={item.href}
          class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 ${
            isActive
              ? 'bg-primary-50 text-primary-700'
              : 'text-text-secondary hover:bg-surface-hover hover:text-text-primary'
          }`}
        >
          <span class={`shrink-0 ${isActive ? 'text-primary-600' : 'text-text-muted'}`} set:html={item.icon} />
          {item.label}
          {isActive && <span class="ml-auto w-1.5 h-1.5 rounded-full bg-primary-500" />}
        </a>
      )
    })}
  </nav>

  <div class="px-4 py-4 border-t border-border-light">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 rounded-full bg-gradient-to-br from-primary-500 to-violet-500 flex items-center justify-center text-white text-xs font-bold shrink-0">
        {user.full_name?.charAt(0)?.toUpperCase() || 'U'}
      </div>
      <div class="min-w-0 flex-1">
        <div class="text-sm font-semibold text-text-primary truncate">{user.full_name}</div>
        <div class="text-xs text-text-muted capitalize">{user.role} &middot; {user.branch}</div>
      </div>
    </div>
  </div>
</aside>

<!-- Overlay for mobile sidebar -->
<div id="sidebar-overlay" class="fixed inset-0 z-30 bg-black/40 backdrop-blur-sm transition-opacity duration-300 opacity-0 pointer-events-none lg:hidden"></div>
