---
export interface Props {
  totalStudents: number
  newLeads: number
  appliedStudents: number
  visaApproved: number
  todayFollowups: number
  pendingDocuments: number
}

const { totalStudents, newLeads, appliedStudents, visaApproved, todayFollowups, pendingDocuments } = Astro.props
const cards = [
  { label: 'Total Students', value: totalStudents, color: 'bg-indigo-600' },
  { label: 'New Leads', value: newLeads, color: 'bg-emerald-500' },
  { label: 'Applied', value: appliedStudents, color: 'bg-blue-500' },
  { label: 'Visa Approved', value: visaApproved, color: 'bg-green-500' },
  { label: "Today's Follow-ups", value: todayFollowups, color: 'bg-amber-500' },
  { label: 'Pending Documents', value: pendingDocuments, color: 'bg-rose-500' },
]
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-4">
  {cards.map(card => (
    <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
      <div class={`w-3 h-3 rounded-full ${card.color} mb-2`} />
      <div class="text-2xl font-bold text-gray-900">{card.value}</div>
      <div class="text-sm text-gray-500 mt-1">{card.label}</div>
    </div>
  ))}
</div>
