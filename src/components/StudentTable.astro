---
import type { Student } from '../types/student'

export interface Props {
  students: Student[]
  showActions?: boolean
}

const { students, showActions = true } = Astro.props
---

<div class="overflow-x-auto bg-white rounded-xl border border-gray-200 shadow-sm">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200 bg-gray-50 text-left text-gray-600 font-medium">
        <th class="px-4 py-3">Name</th>
        <th class="px-4 py-3">Mobile</th>
        <th class="px-4 py-3">Source</th>
        <th class="px-4 py-3">Status</th>
        <th class="px-4 py-3">Branch</th>
        <th class="px-4 py-3">Created</th>
        {showActions && <th class="px-4 py-3 text-right">Actions</th>}
      </tr>
    </thead>
    <tbody>
      {students.map(s => (
        <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
          <td class="px-4 py-3 font-medium text-gray-900">
            <a href={`/students/${s.id}`} class="hover:text-indigo-600">{s.name}</a>
          </td>
          <td class="px-4 py-3 text-gray-600">{s.mobile}</td>
          <td class="px-4 py-3">
            <span class="capitalize text-xs bg-gray-100 text-gray-700 px-2 py-0.5 rounded-full">
              {s.lead_source.replace('_', ' ')}
            </span>
          </td>
          <td class="px-4 py-3">
            <span class="capitalize text-xs font-medium px-2 py-0.5 rounded-full
              {s.status === 'lead' && 'bg-yellow-100 text-yellow-800'}
              {s.status === 'visa_approved' && 'bg-green-100 text-green-800'}
              {s.status === 'applied' && 'bg-blue-100 text-blue-800'}
              {s.status === 'joined' && 'bg-emerald-100 text-emerald-800'}
              {s.status === 'cancelled' && 'bg-red-100 text-red-800'}
            ">
              {s.status.replace(/_/g, ' ')}
            </span>
          </td>
          <td class="px-4 py-3 text-gray-600 capitalize">{s.branch}</td>
          <td class="px-4 py-3 text-gray-500 text-xs">
            {new Date(s.created_at).toLocaleDateString()}
          </td>
          {showActions && (
            <td class="px-4 py-3 text-right">
              <a
                href={`/students/${s.id}`}
                class="text-indigo-600 hover:text-indigo-800 text-sm font-medium"
              >
                View
              </a>
            </td>
          )}
        </tr>
      ))}
    </tbody>
  </table>
  {students.length === 0 && (
    <div class="p-8 text-center text-gray-400">No students found</div>
  )}
</div>
